rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRequest(data) {
      return data.id is string && data.id.size() <= 100
        && data.containerNumber is string && data.containerNumber.size() <= 50
        && data.priority is string && data.priority in ['LOW', 'MEDIUM', 'HIGH', 'URGENT']
        && data.category is string && data.category in ['Electrical', 'Structural', 'Refrigeration/Telematics', 'Mechanical']
        && data.description is string && data.description.size() <= 5000
        && (!('photoUrl' in data) || data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 10000000))
        && data.reporterName is string && data.reporterName.size() <= 200
        && data.timestamp is string
        && data.status is string && data.status in ['WAITING', 'IN_PROGRESS', 'DONE', 'CANCELLED']
        && data.location is string && data.location in ['Timika', 'Surabaya']
        && data.updatedAt is string
        && (!('repairPhotoUrl' in data) || data.repairPhotoUrl == null || (data.repairPhotoUrl is string && data.repairPhotoUrl.size() <= 10000000))
        && (!('resolutionNotes' in data) || data.resolutionNotes == null || (data.resolutionNotes is string && data.resolutionNotes.size() <= 5000))
        && (!('cancellationReason' in data) || data.cancellationReason == null || (data.cancellationReason is string && data.cancellationReason.size() <= 5000));
    }

    match /requests/{requestId} {
      allow read: if isSignedIn() && isValidId(requestId);

      allow create: if isSignedIn() 
        && isValidId(requestId) 
        && isValidRequest(request.resource.data);

      allow update: if isSignedIn()
        && isValidId(requestId)
        && isValidRequest(request.resource.data)
        && (resource.data.status != 'DONE' && resource.data.status != 'CANCELLED' || request.resource.data.status == resource.data.status);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
